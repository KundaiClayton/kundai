---
import { Image } from 'astro:assets';
import Tag from './Tag.astro';
import { getFeaturedContent } from '../lib/notion';

// Define the Essay type based on your Notion data structure
interface Essay {
  id: string;
  title: string;
  description: string;
  date: string;
  coverImage: string;
  status: string;
  tags: string[];
  slug: string;
  externalLinks?: {
    title: string;
    url: string;
  }[];
}

// Accept essays as a prop or fetch from Notion if not provided
interface Props {
  essays?: Essay[];
}

const { essays: propEssays } = Astro.props;

// Fetch essays from Notion if not provided as props
let essays: Essay[] = [];
if (propEssays) {
  essays = propEssays;
} else {
  try {
    essays = await getFeaturedContent('Essay');
  } catch (error) {
    console.error('Error fetching featured essays:', error);
  }
}

// Fallback data if no essays are available
const fallbackEssays: Essay[] = [
  {
    id: "design-systems",
    title: "The Evolution of Design Systems",
    description:
      "Exploring how design systems have evolved from simple style guides to complex, living documentation that shapes product development.",
    date: "May 15, 2023",
    coverImage: "https://picsum.photos/600/400",
    status: "complete",
    tags: ["Design", "Systems", "Documentation"],
    slug: "design-systems"
  },
  {
    id: "digital-minimalism",
    title: "Digital Minimalism: Finding Focus in a Noisy World",
    description:
      "An exploration of how minimalist principles can be applied to our digital lives to reduce distraction and increase meaning.",
    date: "April 22, 2023",
    coverImage: "https://picsum.photos/600/400?random=2",
    status: "complete",
    tags: ["Minimalism", "Digital", "Focus"],
    slug: "digital-minimalism"
  },
];

console.log('Essays:', essays);

// Use real essays if available, otherwise fallback
const displayEssays = essays.length > 0 ? essays : fallbackEssays;
---

<section class="mb-16">
  <div class="mb-6">
    <h2 class="text-2xl md:text-3xl font-bold mb-2">Featured Essays</h2>
    <p class="text-gray-400">Longer, more polished pieces on design, technology, and creativity.</p>
    <div class="accent-underline"></div>
  </div>
  <div class="space-y-8">
    {
      displayEssays.map((essay) => (
        <article class="grid md:grid-cols-2 gap-6 bg-[#1e242a] rounded-lg overflow-hidden">
          <div class="relative">
            <div class="absolute top-4 left-4 z-10">
              <Tag variant={essay.status === "complete" ? "orange" : "dark"}>
                {essay.status === "complete" ? "Complete" : "WIP"}
              </Tag>
            </div>
            {essay.coverImage ? (
              <img
                src={essay.coverImage}
                alt={essay.title}
                width={600}
                height={400}
                class="h-full w-full object-cover"
              />
            ) : (
              <div class="h-full w-full bg-gray-800 flex items-center justify-center">
                <span class="text-gray-500">No image available</span>
              </div>
            )}
          </div>
          <div class="p-6 flex flex-col">
            <div class="mb-2 text-sm text-gray-400">{essay.date}</div>
            <h3 class="text-xl font-bold mb-2">{essay.title}</h3>
            <p class="text-gray-300 mb-6">{essay.description}</p>
            <div class="mt-auto flex flex-wrap gap-2 mb-4">
              {essay.tags.map((tag) => (
                <Tag variant="dark">
                  {tag}
                </Tag>
              ))}
            </div>
            <a 
              href={`/blog/${essay.slug}`}
              class="text-accent-orange hover:text-accent-orange/80 font-medium mt-auto inline-block"
            >
              Read more →
            </a>
          </div>
        </article>
      ))
    }
  </div>
</section>