---
import Tag from './Tag.astro';
import { getRecentContent } from '../lib/notion';

interface Note {
  id: string;
  title: string;
  description: string;
  date: string;
  status: string;
  tags: string[];
  slug: string;
  coverImage: string | null;
}

// Define props interface to allow passing notes from parent
interface Props {
  notes?: Note[];
}

const { notes: propNotes } = Astro.props;

// Fetch notes from Notion if not provided as props
let notes: Note[] = [];
if (propNotes) {
  notes = propNotes;
} else {
  try {
    // Fetch the 3 most recent notes from Notion
    notes = await getRecentContent('Note', 3);
    console.log('Fetched recent notes:', notes);
  } catch (error) {
    console.error('Error fetching recent notes:', error);
  }
}

// Fallback data if no notes are available from Notion
const fallbackNotes: Note[] = [
  {
    id: "typography-tips",
    title: "Typography Tips for Developers",
    description:
      "A collection of practical typography tips that developers can easily implement to improve readability.",
    date: "June 1, 2023",
    status: "wip",
    tags: ["Design", "Typography", "Development"],
    slug: "typography-tips",
    coverImage: null
  },
  {
    id: "zettelkasten",
    title: "Zettelkasten Note-Taking Method",
    description:
      "Quick thoughts on implementing the Zettelkasten method for better knowledge management and idea connections.",
    date: "May 10, 2023",
    status: "complete",
    tags: ["Productivity", "Notes"],
    slug: "zettelkasten",
    coverImage: null
  },
  {
    id: "react-performance",
    title: "React Performance Optimization Techniques",
    description: "A collection of techniques to optimize React applications for better performance.",
    date: "May 5, 2023",
    status: "complete",
    tags: ["React", "Performance", "JavaScript"],
    slug: "react-performance",
    coverImage: null
  },
];

// Use fetched notes if available, otherwise use fallback
const displayNotes = notes.length > 0 ? notes : fallbackNotes;
---

<section class="mb-16">
  <div class="mb-6">
    <h2 class="text-2xl md:text-3xl font-bold mb-2">Recent Notes</h2>
    <p class="text-gray-400">Shorter thoughts, observations, and works in progress.</p>
  </div>
  <div class="grid md:grid-cols-3 gap-6">
    {
      displayNotes.map((note) => (
        <article class="bg-[#1e242a] rounded-lg p-6 flex flex-col h-full">
          <div class="mb-2 flex justify-between items-center">
            <div class="text-sm text-gray-400">{note.date}</div>
            <Tag variant={note.status === "complete" ? "orange" : "dark"}>
              {note.status === "complete" ? "Complete" : "WIP"}
            </Tag>
          </div>
          <h3 class="text-lg font-bold mb-2">{note.title}</h3>
          <p class="text-gray-300 text-sm mb-6">{note.description}</p>
          <div class="mt-auto flex flex-wrap gap-2 mb-4">
            {note.tags.map((tag) => (
              <Tag variant="dark">
                {tag}
              </Tag>
            ))}
          </div>
          <a 
            href={`/blog/${note.slug}`}
            class="text-accent-orange hover:text-accent-orange/80 font-medium mt-auto inline-block"
          >
            Read more →
          </a>
        </article>
      ))
    }
  </div>
  <div class="mt-10 text-center">
    <a
      href="/garden"
      class="inline-flex items-center px-4 py-2 border border-gray-700 rounded-md text-sm font-medium hover:bg-gray-800 transition-colors"
    >
      Explore the Garden →
    </a>
  </div>
</section>