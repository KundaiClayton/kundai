---
interface Props {
  variant?: 'orange' | 'dark';
}

const { variant = 'dark' } = Astro.props;

const variantClasses = {
  orange:
    'bg-orange-500/10 text-orange-500 border-orange-500/30 hover:bg-orange-500/20 hover:border-orange-500/60',
  dark:
    'bg-gray-800/60 text-gray-400 border-gray-700 hover:border-orange-500/40 hover:text-white',
};
---

<span
  class:list={[
    'inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full border transition-colors duration-200',
    variantClasses[variant],
  ]}
>
  <slot />
</span>
