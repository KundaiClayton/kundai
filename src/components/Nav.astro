---
import Logo from './Logo.astro';

const navItems = [
  { title: "Garden", url: "/garden" },
  { title: "Now", url: "/now" },
  { title: "About", url: "/about" },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  pathname === href || (href !== "/" && pathname?.startsWith(href));
---

<header
  class="sticky top-0 z-50 backdrop-blur-md bg-background/70 border-b border-gray-800/60"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-8 lg:px-12 h-16 flex justify-between items-center">
    <a href="/" class="flex items-center" aria-label="Home">
      <Logo />
    </a>

    <nav class="flex items-center gap-1 sm:gap-2">
      {navItems.map(({ title, url }) => {
        const active = isActive(url);
        return (
          <a
            href={url}
            data-active={active}
            class:list={[
              "relative px-3 sm:px-4 py-2 text-sm font-medium transition-colors group",
              active ? "text-white" : "text-gray-400 hover:text-white",
            ]}
          >
            <span class="relative inline-flex items-center gap-1.5">
              {title}
              {active && (
                <span class="w-1 h-1 rounded-full bg-orange-500"></span>
              )}
            </span>
            <span
              class:list={[
                "absolute left-3 right-3 sm:left-4 sm:right-4 bottom-1 h-px bg-orange-500 origin-left transition-transform duration-300",
                active ? "scale-x-100" : "scale-x-0 group-hover:scale-x-100",
              ]}
            ></span>
          </a>
        );
      })}
    </nav>
  </div>
</header>
