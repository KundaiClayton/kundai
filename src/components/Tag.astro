---
interface Props {
  variant?: 'orange' | 'dark';
}

const { variant = 'dark' } = Astro.props;

const variantClasses = {
  orange: 'bg-orange-500/10 text-orange-500',
  dark: 'bg-gray-800 text-gray-400'
};
---

<span class={`inline-block px-2 py-1 text-xs rounded-md ${variantClasses[variant]}`}>
  <slot />
</span>