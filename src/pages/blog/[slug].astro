---
// src/pages/blog/[slug].astro
import { getAllPublished, getSingleBlogPostBySlug } from '../../lib/notion';
import BlogContent from '../../components/BlogContent';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getAllPublished();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { slug } = Astro.params;
const postData = await getSingleBlogPostBySlug(slug);

// Debug log
console.log('Post markdown content:', postData.markdown);
---
<Layout>
<div class="container mx-auto px-4 mt-8 pt-8">
  <main class="max-w-4xl mx-auto py-6">
    <article>
      <div class="text-center mb-12">
        <h1 class="text-3xl sm:text-4xl font-bold text-white/80 mb-4">
          {postData.metadata.title}
        </h1>
        <time class="text-sm text-white/40 mb-6 block">
          {postData.metadata.date}
        </time>
        <div class="flex flex-wrap gap-2 justify-center">
          {postData.metadata.tags.map((tag) => (
            <span class="px-3 py-1 bg-background/50 rounded-full text-sm text-white/60">
              {tag}
            </span>
          ))}
        </div>
      </div>

     

      <BlogContent 
        content={postData.markdown} 
        client:load
      />
    </article>
  </main>
</div></Layout>