---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Tag from '../components/Tag.astro';

// Define your social links
const socialLinks = [
  {
    platform: "Twitter",
    description: "Sharing thoughts and updates on design and technology",
    url: "https://twitter.com",
    handle: "@johndoe"
  },
  {
    platform: "GitHub",
    description: "Code, open source projects, and experiments",
    url: "https://github.com",
    handle: "github.com/johndoe"
  },
  {
    platform: "LinkedIn",
    description: "Professional experience and day-to-day work experience",
    url: "https://linkedin.com",
    handle: "linkedin.com/in/johndoe"
  }
];

// Define your projects
const projects = [
  {
    title: "Personal Digital Garden",
    description: "An ongoing digital garden built with Next.js and Tailwind CSS, focused on essays, notes, code, and projects.",
    image: "https://picsum.photos/800/400",
    tags: ["Next.js", "TypeScript", "Jamstack"],
    link: "#"
  },
  {
    title: "Minimalist UI Component Library",
    description: "A collection of accessible, component-based UI elements designed with minimalism and accessibility in mind.",
    image: "https://picsum.photos/800/400?random=2",
    tags: ["React", "TypeScript", "Accessibility"],
    link: "#"
  },
  {
    title: "Markdown Note Editor",
    description: "A distraction-free markdown editor for taking notes and text parsing with local storage.",
    image: "https://picsum.photos/800/400?random=3",
    tags: ["JavaScript", "Markdown", "LocalStorage"],
    link: "#"
  }
];

const profileImage = "https://picsum.photos/100/100";
---

<Layout title="About | Kundai Clayton">
  <div class="space-y-10">
    <section>
      <h1 class="text-3xl font-bold mb-2">About Me</h1>
      <p class="text-gray-300">
        Designer, developer, and writer exploring the intersection of technology and creativity.
      </p>
    </section>

    <section class="grid md:grid-cols-3 gap-8">
      <div class="md:col-span-2 space-y-6 text-gray-300">
        <div class="flex gap-6 items-start">
          <div class="flex-shrink-0">
            <Image
              src={profileImage}
              alt="Profile"
              width={100}
              height={100}
              class="rounded"
            />
          </div>
          <p>
            Hello! I'm John, a designer and developer with a passion for creating interfaces, functional systems, and
            thoughtful digital experiences.
          </p>
        </div>

        <p>
          I currently work as a senior designer at a tech company, where I focus on creating component-based design
          systems and interfaces. My background in both design and development allows me to bridge the gap between
          aesthetics and implementation.
        </p>

        <p>
          This digital garden is my space to think openly about design, technology, and creativity. It's a collection
          of essays, notes, and thoughts on topics I'm exploring, including design systems, typography, interaction,
          and the intersection of technology and humanity.
        </p>

        <p>
          When I'm not designing or coding, you can find me reading books on philosophy and design, experimenting with
          photography, and hiking in the mountains.
        </p>
      </div>

      <div class="space-y-6">
        <div class="bg-[#1e242a] rounded-lg p-5">
          <h2 class="text-lg font-bold mb-4">Connect</h2>

          <div class="space-y-4">
            {socialLinks.map(({ platform, description, url, handle }) => (
              <div>
                <h3 class="font-medium mb-1">{platform}</h3>
                <p class="text-sm text-gray-400">{description}</p>
                <a href={url} class="text-orange-500 text-sm hover:underline">
                  {handle}
                </a>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-6">Projects</h2>

      <div class="space-y-8">
        {projects.map((project) => (
          <div>
            <Image
              src={project.image}
              alt={project.title}
              width={800}
              height={400}
              class="w-full h-64 object-cover rounded-lg mb-4"
            />
            <h3 class="text-xl font-bold mb-1">{project.title}</h3>
            <p class="text-gray-300 mb-3">
              {project.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <Tag variant="dark">{tag}</Tag>
              ))}
            </div>
            <a href={project.link} class="block mt-3 text-orange-500 hover:underline">
              View Project →
            </a>
          </div>
        ))}
      </div>
    </section>
  </div>
</Layout>