---
interface ExternalLink {
  title: string;
  url: string;
}

interface Props {
  links: ExternalLink[];
  variant?: 'default' | 'buttons' | 'minimal';
  className?: string;
}

const { 
  links = [], 
  variant = 'default',
  className = ''
} = Astro.props;

// Don't render anything if no links
if (links.length === 0) {
  return null;
}

