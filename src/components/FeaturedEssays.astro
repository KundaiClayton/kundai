---
import { getFeaturedContent } from '../lib/notion';

interface Essay {
  id: string;
  title: string;
  description: string;
  date: string;
  coverImage: string;
  status: string;
  tags: string[];
  slug: string;
  externalLinks?: {
    title: string;
    url: string;
  }[];
}

interface Props {
  essays?: Essay[];
}

const { essays: propEssays } = Astro.props;

let essays: Essay[] = [];
if (propEssays) {
  essays = propEssays;
} else {
  try {
    essays = await getFeaturedContent('Essay');
  } catch (error) {
    console.error('Error fetching featured essays:', error);
  }
}
---

<section class="max-w-4xl mx-auto mb-20">
  <hr class="border-gray-800 mb-20" />

  <div class="mb-10 flex items-end justify-between flex-wrap gap-4">
    <div>
      <p class="text-xs uppercase tracking-[0.25em] text-gray-500 font-mono mb-3">02 / Featured essays</p>
      <h2 class="text-3xl sm:text-4xl font-bold accent-underline">Longer reads</h2>
    </div>
    <a
      href="/garden?type=essay"
      class="text-sm font-mono text-orange-500 hover:underline"
    >
      All essays →
    </a>
  </div>

  {essays.length === 0 ? (
    <div class="border border-dashed border-gray-800 rounded-xl p-10 text-center">
      <p class="text-gray-500 italic">
        No featured essays yet — the garden is still being seeded.
      </p>
    </div>
  ) : (
    <div class="divide-y divide-gray-800 border-y border-gray-800">
      {essays.map((essay, idx) => (
        <a
          href={`/blog/${essay.slug}`}
          class="block py-8 first:pt-8 last:pb-8 group"
        >
          <div class="flex items-baseline gap-4 mb-3 flex-wrap">
            <span class="text-xs font-mono text-gray-600">0{idx + 1}</span>
            <span class="text-xs uppercase tracking-wider font-mono text-orange-500">
              {essay.status === "complete" ? "Complete" : "WIP"}
            </span>
            <span class="text-xs font-mono text-gray-500 ml-auto">{essay.date}</span>
          </div>
          <h3 class="text-2xl sm:text-3xl font-bold mb-3 group-hover:text-orange-500 transition-colors pl-8">
            {essay.title}
          </h3>
          <p class="text-gray-300 leading-relaxed mb-4 pl-8 max-w-3xl">
            {essay.description}
          </p>
          <div class="flex items-center gap-3 pl-8 flex-wrap">
            <div class="flex flex-wrap gap-2">
              {essay.tags.map((tag) => (
                <span class="text-xs px-2.5 py-1 rounded-full bg-gray-800/60 text-gray-400 border border-gray-700">{tag}</span>
              ))}
            </div>
            <span class="text-sm font-mono text-orange-500 ml-auto group-hover:translate-x-1 transition-transform">
              Read →
            </span>
          </div>
        </a>
      ))}
    </div>
  )}
</section>
